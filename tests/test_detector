"""
test_detector.py
------------------
Unit tests for the PlagiarismDetector class and supporting utility functions.

Run with:
    pytest tests/test_detector.py -v
"""

import pytest

from app.detector import PlagiarismDetector
from app.utils import clean_text, split_into_sentences, format_percentage


@pytest.fixture(scope="module")
def detector():
    """Creates a single shared detector instance for all tests in this module
    (loading the embedding model is expensive, so we avoid reloading it per test)."""
    return PlagiarismDetector()


# ----------------------------
# Utility function tests
# ----------------------------

def test_clean_text_lowercases_and_strips_punctuation():
    raw = "Hello, World! This IS a Test."
    cleaned = clean_text(raw)
    assert cleaned == "hello world this is a test"


def test_clean_text_collapses_whitespace():
    raw = "This   has\n\nextra   whitespace."
    cleaned = clean_text(raw)
    assert "  " not in cleaned


def test_split_into_sentences_basic():
    text = "This is sentence one. This is sentence two! Is this sentence three?"
    sentences = split_into_sentences(text)
    assert len(sentences) == 3


def test_split_into_sentences_filters_short_fragments():
    text = "Hi. This is a much longer valid sentence for testing purposes."
    sentences = split_into_sentences(text)
    # "Hi." should be filtered out for being below MIN_CHUNK_LENGTH
    assert all(len(s) >= 10 for s in sentences)


def test_format_percentage():
    assert format_percentage(0.5) == "50.00%"
    assert format_percentage(1.0) == "100.00%"
    assert format_percentage(0.0) == "0.00%"


# ----------------------------
# Detector logic tests
# ----------------------------

def test_identical_texts_have_high_similarity(detector):
    text = "The quick brown fox jumps over the lazy dog."
    result = detector.compare_texts(text, text)
    assert result["similarity_score"] > 0.99
    assert result["verdict"] == "High Risk of Plagiarism"


def test_completely_different_texts_have_low_similarity(detector):
    text1 = "The stock market saw significant gains today amid strong earnings reports."
    text2 = "Penguins are flightless birds that live primarily in the Southern Hemisphere."
    result = detector.compare_texts(text1, text2)
    assert result["similarity_score"] < 0.75
    assert result["verdict"] == "Original"


def test_paraphrased_text_is_flagged_as_possible_plagiarism(detector):
    original = "Artificial intelligence enables machines to learn from data and improve over time."
    paraphrased = "AI allows computer systems to learn from information and get better as time passes."
    result = detector.compare_texts(original, paraphrased)
    # Paraphrasing should still register meaningfully high similarity
    assert result["similarity_score"] > 0.5


def test_compare_sentence_level_returns_expected_structure(detector):
    text1 = "Machine learning is a subset of AI. It helps computers learn from data."
    text2 = "Machine learning is a branch of AI. It allows computers to learn from data."

    results = detector.compare_sentence_level(text1, text2)

    assert isinstance(results, list)
    assert len(results) > 0
    for item in results:
        assert "source_sentence" in item
        assert "matched_sentence" in item
        assert "similarity_score" in item
        assert "flagged" in item


def test_check_against_corpus_returns_sorted_results(detector):
    text = "Artificial intelligence is the simulation of human intelligence by machines."
    corpus = {
        "doc_high_match.txt": "Artificial intelligence is the simulation of human intelligence by machines.",
        "doc_low_match.txt": "Bananas are a popular tropical fruit rich in potassium.",
    }

    results = detector.check_against_corpus(text, corpus)

    assert len(results) == 2
    # Results should be sorted with highest similarity first
    assert results[0]["similarity_score"] >= results[1]["similarity_score"]
    assert results[0]["document"] == "doc_high_match.txt"


def test_get_verdict_thresholds(detector):
    assert detector._get_verdict(0.95) == "High Risk of Plagiarism"
    assert detector._get_verdict(0.80) == "Possible Plagiarism"
    assert detector._get_verdict(0.40) == "Original"
